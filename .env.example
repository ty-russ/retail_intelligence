# Copy to .env and fill in the keys you have. The app falls back gracefully —
# any model whose key is missing just returns an error message, the others run.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-...

# Google (Gemini 1.5 Pro)
GOOGLE_API_KEY=AIza...

# Optional: override the React client's API base URL (defaults to localhost:8000)
# VITE_API_BASE=http://localhost:8000
